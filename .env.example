# DealRadar — Konfiguration
# Kopiere diese Datei zu .env und passe die Werte an

# Amazon Affiliate Tag
AMAZON_ASSOCIATE_TAG=DealRadar-21

# Server
PORT=8000
HOST=0.0.0.0

# Frontend URL (für CORS)
FRONTEND_URL=http://localhost:5173

# Cache-Dauer in Stunden
CACHE_HOURS=24

# Nächtlicher Job (Uhrzeit, 24h)
SCHEDULER_HOUR=3
SCHEDULER_MINUTE=0
